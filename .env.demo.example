# LineUp Lab — demo deployment env vars
#
# This is a TEMPLATE. Copy to .env.demo (gitignored) and fill in with
# the demo Supabase project credentials. Then set the same vars in the
# Vercel project pointing at lineup-lab.vercel.app.
#
# DO NOT use the auction-bhai (Mumbai) Supabase project here. Create a
# separate one.

# ---- Site mode ----
NEXT_PUBLIC_SITE_MODE=demo

# ---- Demo Supabase project ----
# Get these from Supabase dashboard → Settings → API + Connection
NEXT_PUBLIC_SUPABASE_URL=https://<demo-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<demo anon key>
SUPABASE_SERVICE_ROLE_KEY=<demo service role key>

# Direct connection (Postgres) — used by scripts + drizzle. Postgres
# connection string from Supabase → Settings → Database → Direct
# connection.
DATABASE_URL=postgres://postgres:<password>@db.<demo-ref>.supabase.co:5432/postgres

# ---- football-data.org ----
# Reuse the same key as auction-bhai (free tier allows shared use)
FOOTBALL_DATA_API_KEY=<your football-data.org token>

# ---- Demo reset cron ----
# Set this to enable POST /api/demo-reset (nightly state wipe).
# Generate a random string: openssl rand -hex 32
DEMO_RESET_TOKEN=<random hex string, treat as a secret>

# ---- Allowed signup emails ----
# Not used in demo mode (signups disabled at app level), but harmless.
ALLOWED_EMAILS=
