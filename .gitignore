# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example
!.env.demo.example

# Claude Code assistant local state
.claude/

# Hand-imported raw datasets (Kaggle CSVs, etc.) — too large for git
/lib/data/*.csv
/lib/data/*.csv.gz
/lib/data/*.zip
!/lib/data/.gitkeep
# Kaggle downloads tend to land at the project root
/archive.zip
/*.csv.zip

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
