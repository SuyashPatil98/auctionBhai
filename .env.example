# ---- Supabase ----
# From your Supabase project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — server only, never exposed to browser
SUPABASE_SERVICE_ROLE_KEY=

# ---- Database (Drizzle) ----
# Supabase pooler URL (Settings > Database > Connection pooling > "Transaction" mode)
# Example: postgresql://postgres.YOUR_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres
DATABASE_URL=

# ---- App ----
# Sign-up allowlist — comma-separated emails of the 4 managers.
# Only these emails can create accounts. Sign-in itself is unrestricted
# (anyone with valid credentials gets in), but Supabase Auth only knows
# about users who managed to sign up in the first place.
ALLOWED_EMAILS=alice@example.com,bob@example.com,carol@example.com,dave@example.com

# Set to your Vercel URL in production
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---- football-data.org ----
# Free tier: 10 requests/minute. Register at https://www.football-data.org/client/register
# Sent as X-Auth-Token header.
FOOTBALL_DATA_API_KEY=

# ---- Scheduled sync (cron) ----
# Protects the /api/cron/sync endpoint (pulls scores, scores predictions,
# settles standings). Vercel Cron sends this automatically as
# `Authorization: Bearer <CRON_SECRET>`. Set the same value in the Vercel
# project's env vars. A free external pinger (e.g. cron-job.org) can call the
# endpoint with the same header for live cadence on Hobby. Generate any random
# string, e.g. `openssl rand -hex 32`. If unset, the endpoint is unauthenticated.
CRON_SECRET=

# ---- AI (Smart Search) ----
# https://aistudio.google.com/app/apikey  — Gemini 2.5 Flash, free tier
GEMINI_API_KEY=

# ---- Inngest (scheduled jobs) ----
# Get from https://app.inngest.com after creating an app
INNGEST_SIGNING_KEY=
INNGEST_EVENT_KEY=

# ---- Sentry (optional) ----
SENTRY_AUTH_TOKEN=
