# ---- Supabase ----
# From your Supabase project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — server only, never exposed to browser
SUPABASE_SERVICE_ROLE_KEY=

# ---- Database (Drizzle) ----
# Supabase pooler URL (Settings > Database > Connection pooling > "Transaction" mode)
# Example: postgresql://postgres.YOUR_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres
DATABASE_URL=

# ---- App ----
# Magic-link allowlist — comma-separated emails of the 4 managers
ALLOWED_EMAILS=alice@example.com,bob@example.com,carol@example.com,dave@example.com

# Used by magic-link redirect; set to your Vercel URL in production
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---- AI (Smart Search) ----
# https://aistudio.google.com/app/apikey  — Gemini 2.5 Flash, free tier
GEMINI_API_KEY=

# ---- Inngest (scheduled jobs) ----
# Get from https://app.inngest.com after creating an app
INNGEST_SIGNING_KEY=
INNGEST_EVENT_KEY=

# ---- Sentry (optional) ----
SENTRY_AUTH_TOKEN=
