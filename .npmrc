# Stop pnpm from running `pnpm install` before every script.
# The install errors on the build-script approval gate (sharp, etc.),
# which blocks unrelated commands like `pnpm typecheck` and `pnpm dev`.
verify-deps-before-run=false

# Build scripts we explicitly trust to run post-install.
# Mirrors package.json#pnpm.onlyBuiltDependencies for pnpm versions
# that read the .npmrc form.
auto-install-peers=true
